# Copy to dev/.env and fill in.

# Base URL of the real FortiSOAR instance, no trailing slash.
FORTISOAR_HOST=https://your-soar-host.example.com

# Credentials used to fetch a JWT via POST /auth/authenticate.
# The server caches the token in memory, refreshes before expiry, and
# re-authenticates if a proxied request comes back 401.
FORTISOAR_USERNAME=
FORTISOAR_PASSWORD=

# Local port for the harness.
PORT=4400
