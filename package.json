{
  "name": "fortisoar-widget-harness",
  "version": "0.1.0",
  "description": "Local dev harness for FortiSOAR 7.x AngularJS widgets: render in isolation, proxy /api/* to a real instance, package + install with one click.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest",
    "test:live": "jest -c jest.live.config.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint:testids": "node scripts/lint-testids.js fsrPlaybookBuilder",
    "lint:testids:all": "node scripts/lint-testids.js",
    "lint:angular": "node scripts/lint-angular.js fsrPlaybookBuilder",
    "lint:angular:all": "node scripts/lint-angular.js",
    "lint:js": "cd .. && find widgets-src -name '*.js' ! -name '*.min.js' -not -path '*/node_modules/*' -not -path '*/lib/*' -not -path '*/vendor/*' -print0 | xargs -0 oxlint -c widgets-src/.oxlintrc.json",
    "lint:eslint": "eslint --resolve-plugins-relative-to . --ext .js ../widgets-src",
    "lint": "npm run lint:js && npm run lint:eslint && npm run lint:testids && npm run lint:angular",
    "widget": "node scripts/widget.js",
    "ship": "node scripts/widget.js ship",
    "verify-remote": "node scripts/widget.js verify-remote"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "http-proxy-middleware": "^3.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "angular": "1.8",
    "angular-mocks": "1.8",
    "eslint": "^8.57.1",
    "eslint-plugin-angular": "^4.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "oxlint": "^1.0.0",
    "supertest": "^7.0.0"
  },
  "license": "MIT"
}
